# 默认：所有文本文件统一用 LF 存储，checkout 时不转换
* text=auto eol=lf

# 明确为文本的文件类型
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.proto text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.env   text eol=lf

# Windows 批处理脚本保留 CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# 二进制文件不做换行处理
*.exe   binary
*.out   binary
*.png   binary
*.jpg   binary
*.gif   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
