{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Server (Coordinator)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/server",
      "env": {},
      "args": []
    },
    {
      "name": "Debug: Worker (Executor)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/worker",
      "env": {},
      "args": []
    },
    {
      "name": "Debug: Current Test File",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-v", "-run", "${selectedText}"]
    },
    {
      "name": "Debug: All Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/...",
      "args": ["-v", "-race"]
    }
  ]
}
